generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name      String
  slug      String   @unique
  phone     String?
  address   String?
  city      String?
  state     String?
  zip       String?
  website   String?
  logoUrl         String?
  bccEmail        String?
  replyToEmail    String?
  defaultDueDays  Int     @default(30)
  venmoHandle     String?
  paypalHandle    String?
  cashAppHandle   String?
  zellePhone      String?
  zelleEmail      String?
  stripeAccountId String?   // Stripe Connect connected account ID
  isActive        Boolean @default(true)

  plan          String    @default("trial")  // trial | starter | pro | unlimited
  trialEndsAt   DateTime?
  planNote      String?   // internal admin notes about this company's plan
  planUpdatedAt DateTime?

  stripePlatformCustId  String?   // Stripe Customer ID (platform billing — not Connect)
  stripeSubId           String?   // Active Stripe subscription ID
  stripeSubStatus       String?   // active | trialing | past_due | canceled | unpaid

  lateFeeEnabled  Boolean @default(false)
  lateFeePercent  Float   @default(1.5)
  lateFeeGraceDays Int    @default(0)

  cardFeeEnabled  Boolean @default(false)
  cardFeePercent  Float   @default(2.9)
  cardFeeFixed    Float   @default(0.30)

  users     User[]
  customers Customer[]
  routes    Route[]
  invoices  Invoice[]
  estimates         Estimate[]
  estimateTemplates EstimateTemplate[]
  expenses          Expense[]
  vendors           Vendor[]
  emailLogs         EmailLog[]
  messages          CustomerMessage[]
  tags              Tag[]
  attachments       Attachment[]
  visitChecklist    VisitChecklistItem[]
  dismissedNotifications DismissedNotification[]
  supportTickets         SupportTicket[]
  issueReports           IssueReport[]
}

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  email     String  @unique
  password  String
  firstName String
  lastName  String
  role      String  @default("technician") // owner | technician
  isActive  Boolean @default(true)

  passwordResetToken  String?   @unique
  passwordResetExpiry DateTime?
  mustChangePassword  Boolean   @default(false)
  lastLoginAt         DateTime?

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  assignedRoutes    Route[]             @relation("RouteAssignee")
  serviceVisits     ServiceVisit[]      @relation("VisitTechnician")
  equipmentServices EquipmentService[]  @relation("EquipmentServiceTech")
  submittedTickets  SupportTicket[]     @relation("TicketSubmitter")
  reportedIssues    IssueReport[]       @relation("IssueReporter")
}

model Customer {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  firstName   String
  lastName    String
  email       String?
  phone       String?
  address     String
  city        String
  state       String
  zip         String

  poolType    String?
  poolSize    String?
  poolNotes   String?

  status      String  @default("active")
  monthlyRate Float?
  dueDays     Int?

  stripeCustomerId  String?  // Stripe Customer ID on the company's connected account
  autoPayEnabled    Boolean  @default(false)
  autoPayMethodId   String?  // saved Stripe PaymentMethod ID for auto-pay
  portalToken          String?  @unique
  portalLastAccessedAt DateTime?

  serviceFrequency  String?  // weekly | biweekly | monthly | quarterly | as_needed

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  routeStops    RouteStop[]
  serviceVisits ServiceVisit[]
  invoices      Invoice[]
  estimates     Estimate[]
  equipment     Equipment[]
  notes         CustomerNote[]
  emailLogs     EmailLog[]
  messages      CustomerMessage[]
  alerts        CustomerAlert[]
  tags          CustomerTag[]
  attachments   Attachment[]
  issueReports  IssueReport[]
}

model CustomerNote {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  body       String
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model CustomerMessage {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())

  body         String
  fromCompany  Boolean  @default(true)
  sentViaEmail Boolean  @default(false)
  sentByName   String?

  serviceVisitId String?

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Route {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  name        String
  description String?
  dayOfWeek   Int?
  isActive    Boolean  @default(true)

  assignedUserId String?
  assignedUser   User?   @relation("RouteAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  stops   RouteStop[]
  visits  ServiceVisit[]
}

model RouteStop {
  id         String   @id @default(cuid())
  position   Int
  notes      String?

  routeId    String
  route      Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([routeId, customerId])
  @@index([routeId, position])
}

model ServiceVisit {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  visitedAt DateTime @default(now())

  status    String  @default("completed")
  notes     String?

  chlorine   Float?
  ph         Float?
  alkalinity Float?
  calcium    Float?
  cya        Float?
  salt       Float?
  saltwater  Boolean @default(false)

  routeId    String?
  route      Route?   @relation(fields: [routeId], references: [id])
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  technicianId String?
  technician   User?   @relation("VisitTechnician", fields: [technicianId], references: [id], onDelete: SetNull)

  issueReports IssueReport[]
}

model VisitChecklistItem {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  label     String
  position  Int      @default(0)
  isActive  Boolean  @default(true)
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Invoice {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  invoiceNumber String   @unique
  status        String   @default("draft")
  serviceType   String?  // monthly | repair | equipment | chemical | installation | other
  dueDate       DateTime
  issuedAt      DateTime @default(now())
  paidAt        DateTime?
  notes         String?
  payToken              String?  @unique  // public pay link token
  stripePaymentIntentId String?           // Stripe PaymentIntent ID
  lateFeeApplied        Boolean  @default(false)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  items     InvoiceItem[]
  payments  Payment[]
  emailLogs EmailLog[]
}

model InvoiceItem {
  id          String  @id @default(cuid())
  description String
  quantity    Float   @default(1)
  unitPrice   Float
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Payment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  amount    Float
  method    String?
  reference String?
  notes     String?
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Estimate {
  id             String    @id @default(cuid())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  estimateNumber String    @unique
  status         String    @default("draft") // draft | sent | accepted | declined | converted
  serviceType    String?   // monthly | repair | equipment | chemical | installation | other
  validUntil     DateTime?
  notes          String?
  convertedInvoiceId String?

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  items EstimateItem[]
}

model EstimateItem {
  id          String   @id @default(cuid())
  description String
  quantity    Float    @default(1)
  unitPrice   Float
  estimateId  String
  estimate    Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
}

model Expense {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  date        DateTime
  category    String   // chemicals | equipment | labor | fuel | supplies | office | other
  description String
  amount      Float
  vendor      String?
  notes       String?

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Vendor {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  name      String
  category  String?
  notes     String?

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model EstimateTemplate {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  name        String
  description String?

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  items EstimateTemplateItem[]
}

model EstimateTemplateItem {
  id          String           @id @default(cuid())
  description String
  quantity    Float            @default(1)
  unitPrice   Float
  templateId  String
  template    EstimateTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model Equipment {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  type         String    // pump | filter | heater | salt_system | cleaner | light | other
  brand        String?
  model        String?
  serialNumber String?
  installedAt  DateTime?
  warrantyExpiry   DateTime?
  warrantyProvider String?
  warrantyNotes    String?
  notes        String?

  serviceIntervalDays Int?      // days between routine service (e.g. 90 for quarterly filter clean)
  lastServicedAt      DateTime? // auto-set when a service record is added

  customerId     String
  customer       Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  serviceRecords EquipmentService[]
}

model EquipmentService {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())

  date        DateTime
  description String
  parts       String?
  laborCost   Float    @default(0)
  partsCost   Float    @default(0)
  notes       String?

  technicianId String?
  technician   User?      @relation("EquipmentServiceTech", fields: [technicianId], references: [id], onDelete: SetNull)

  equipmentId  String
  equipment    Equipment  @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
}

model CustomerAlert {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  body       String

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Tag {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  name      String
  color     String   @default("#6b7280")

  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  customers CustomerTag[]

  @@unique([name, companyId])
}

model CustomerTag {
  customerId String
  tagId      String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([customerId, tagId])
}

model Attachment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  key       String   // GCS object key, e.g. "companyId/customerId/1234567890-photo.jpg"
  filename  String
  mimeType  String?
  size      Int?     // bytes

  customerId     String?
  customer       Customer?  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  serviceVisitId String?
  companyId      String
  company        Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model PromoBanner {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  message         String
  code            String?
  active          Boolean   @default(true)
  dismissible     Boolean   @default(true)
  showOnMarketing Boolean   @default(true)
  showInApp       Boolean   @default(true)
  bgColor         String    @default("sky")   // sky | amber | green | purple
  expiresAt       DateTime?
}

model PlanConfig {
  id          String  @id  // "trial" | "starter" | "pro" | "unlimited"
  label       String
  description String  @default("")
  priceMonthly  Int?
  priceAnnual   Int?
  badge         String  @default("bg-gray-100 text-gray-700")
  mostPopular   Boolean @default(false)
  highlights    String[]
  limitCustomers Int    @default(50)
  limitStaff     Int    @default(2)  // -1 = unlimited

  // Feature flags
  invoicing          Boolean @default(false)
  routes             Boolean @default(false)
  customerPortal     Boolean @default(false)
  chemicalTracking   Boolean @default(false)
  emailNotifications Boolean @default(false)
  reports            Boolean @default(false)
  csvExport          Boolean @default(false)
  bulkInvoicing      Boolean @default(false)
  fileAttachments    Boolean @default(false)
  customBranding     Boolean @default(false)
  smsNotifications   Boolean @default(false)
  calendarView       Boolean @default(false)
  techAssignment     Boolean @default(false)
  autoInvoicing      Boolean @default(false)
  quickbooksExport   Boolean @default(false)

  updatedAt DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  name      String
  email     String
  subject   String?
  body      String

  status    String   @default("new")  // new | read | replied

  replyBody  String?
  repliedAt  DateTime?
  repliedBy  String?  // admin display name who sent the reply
}

model EmailLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  type      String   // "invoice" | "reminder" | "receipt" | "estimate" | "visit"
  status    String   // "sent" | "failed"
  toEmail   String
  bccEmail  String?
  subject   String

  invoiceId  String?
  invoice    Invoice?  @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  estimateId String?
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  serviceVisitId String?
}

model SiteConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model WaitlistEntry {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  email     String   @unique
  name      String?
  source    String?
}

model FeatureItem {
  id          String  @id @default(cuid())
  position    Int     @default(0)
  title       String
  description String
  icon        String?
  isActive    Boolean @default(true)
}

model BlogPost {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?
  slug        String    @unique
  title       String
  excerpt     String?
  content     String
  coverImage  String?
  isPublished Boolean   @default(false)
}

model ReferralCode {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  code      String   @unique
  label     String?
  reward    String   @default("1 free month")
  isActive  Boolean  @default(true)
  uses      Referral[]
}

model Referral {
  id             String       @id @default(cuid())
  createdAt      DateTime     @default(now())
  referralCodeId String
  code           ReferralCode @relation(fields: [referralCodeId], references: [id])
  email          String?
  companyId      String?
  status         String       @default("lead")
}

model SupportTicket {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subject   String
  category  String            // billing | technical | feature_request | account | other
  priority  String  @default("normal")  // low | normal | high
  status    String  @default("open")    // open | in_progress | resolved | closed

  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  submittedById String?
  submittedBy   User?    @relation("TicketSubmitter", fields: [submittedById], references: [id], onDelete: SetNull)

  messages SupportTicketMessage[]

  @@index([companyId, status])
}

model SupportTicketMessage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  body       String
  fromAdmin  Boolean @default(false)
  authorName String?

  ticketId String
  ticket   SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

model DismissedNotification {
  companyId      String
  notificationId String
  dismissedAt    DateTime @default(now())
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([companyId, notificationId])
  @@index([companyId])
}

model IssueReport {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category String  // leak | equipment_failure | safety_hazard | water_quality | other
  priority String  @default("normal") // low | normal | high
  status   String  @default("open")   // open | in_progress | resolved
  notes    String

  visitId  String?
  visit    ServiceVisit? @relation(fields: [visitId], references: [id], onDelete: SetNull)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  reportedById String?
  reportedBy   User?    @relation("IssueReporter", fields: [reportedById], references: [id], onDelete: SetNull)

  @@index([companyId, status])
  @@index([customerId])
}
