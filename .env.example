# Netlify Postgres (Neon) — copy these from your Netlify dashboard > Database
DATABASE_URL=""           # pooled connection (for queries)
DATABASE_URL_UNPOOLED=""  # direct connection (for migrations)

# Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Required for NextAuth on Netlify — set to your deployed site URL
AUTH_URL=""

# Your app's public URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email address that gets super admin access
SUPER_ADMIN_EMAIL=""

# Upstash Redis — distributed rate limiting (get from console.upstash.com)
# Leave blank to fall back to in-memory rate limiting (fine for local dev)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Logging — pino level: trace | debug | info | warn | error (default: debug in dev, info in prod)
LOG_LEVEL=""
