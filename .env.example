# Netlify Postgres (Neon) — copy these from your Netlify dashboard > Database
DATABASE_URL=""           # pooled connection (for queries)
DATABASE_URL_UNPOOLED=""  # direct connection (for migrations)

# Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Required for NextAuth on Netlify — set to your deployed site URL
AUTH_URL=""

# Your app's public URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email address that gets super admin access
SUPER_ADMIN_EMAIL=""
